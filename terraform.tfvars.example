# Copy this file to terraform.tfvars and fill in your actual values
# terraform.tfvars is ignored by git for security

# Database passwords
# TODO: Re-enable staging when needed
# staging_db_password = "your-staging-db-password-here"
prod_db_password    = "your-production-db-password-here"

# Key pair name
key_pair_name = "your-key-pair-name"

# TODO: Re-enable staging when needed
